# .env
APP_NAME=Intelligent Retail Decision Making System
VERSION=1.0.0
DEBUG=False
HOST=127.0.0.1
PORT=5050
API_PREFIX=/api/v1

MODEL_CHECKPOINT=yainage90/fashion-object-detection
DETECTION_THRESHOLD=0.4

# JWT (demo)
SECRET_KEY=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
API_TOKEN=


# MLflow Configuration
MLFLOW_TRACKING_URI=http://localhost:5001

# AWS S3 Configuration (for model storage)
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_DEFAULT_REGION=us-east-1
S3_BUCKET=your_s3_bucket_name

# Jenkins Configuration (for DVC pipeline)
JENKINS_URL=http://localhost:8081
JENKINS_TOKEN=dvc-data-change-trigger
JENKINS_USER=admin
JENKINS_API_TOKEN=your-jenkins-api-token-here

# GitHub Configuration
GITHUB_TOKEN=your-github-personal-access-token
GITHUB_REPO=username/project-mlops

# DVC Remote Storage (optional, defaults to local)
# DVC_REMOTE=s3
# DVC_REMOTE_URL=s3://your-bucket/dvc-storage